docker/postgres/data
.git
*.md
node_modules
# Runtime data is mounted as a volume at runtime (../data/ladn:/app/data) and never
# COPYed by the Dockerfile — keep the whole tree out of the build context. (Also avoids
# the context walker tripping on root-owned dirs like data/ladn/assistant-uploads.)
data/
data/*/uploads/*.tmp
# Never bake secrets into images — env vars injected at runtime via docker run / compose env_file
**/.env
# Editor/agent backup files — never referenced by code, keep them out of images
**/*.bak
**/*.bak-*
**/*.pre-*
