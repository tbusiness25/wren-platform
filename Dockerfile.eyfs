FROM node:20-alpine

# WREN_EDITION_ARG kept for compatibility with existing build scripts
ARG EDITION=eyfs
ENV WREN_EDITION_ARG=${EDITION}

WORKDIR /app

# Install rclone for Google Drive resources route; upgrade for security patches
RUN apk add --no-cache rclone wget && apk upgrade --no-cache

COPY package*.json ./
RUN npm ci --only=production

COPY src/ ./src/
COPY public/ ./public/
COPY editions/ ./editions/
COPY scripts/ ./scripts/
COPY shared/ ./shared/

# Only ship static reference JSON — bulk data (uploads, parent-resources) comes from mounted volumes at runtime
RUN mkdir -p /app/data /app/uploads
COPY data/framework-versions.json ./data/
COPY data/field-config.json ./data/

EXPOSE 3000

# All secrets injected at runtime via env vars — nothing baked in.
# Required: PG_HOST PG_PORT PG_DB PG_USER PG_PASSWORD PG_SCHEMA JWT_SECRET
# Optional: DEMO_MODE OLLAMA_HOST GROQ_API_KEY ANTHROPIC_API_KEY SMTP_*

HEALTHCHECK --interval=30s --timeout=10s --start-period=60s --retries=3 \
  CMD wget -qO- http://localhost:3000/healthz || exit 1

CMD ["node", "editions/eyfs/server-unified.js"]
