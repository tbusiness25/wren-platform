# =============================================================================
# Wren EYFS — self-host configuration
# Copy this file to ".env" (cp .env.example .env), edit the values below, then:
#   docker compose up -d
# =============================================================================

# --- Database -----------------------------------------------------------------
# These are used by BOTH the Postgres container and the app. PG_HOST should stay
# "db" (the compose service name) unless you point at an external Postgres.
PG_HOST=db
PG_PORT=5432
PG_DB=wren
PG_USER=wren
# >>> CHANGE THIS before exposing anything to a network. It's the Postgres
# >>> superuser password. Generate a strong one, e.g.:  openssl rand -hex 24
PG_PASSWORD=changeme
# The Postgres schema Wren uses. The bundled seed creates "demo_eyfs"; leave this
# as-is unless you know you want a different schema name.
PG_SCHEMA=demo_eyfs

# --- App ----------------------------------------------------------------------
# >>> CHANGE THIS before exposing anything to a network. Used to sign login
# >>> tokens — anyone who knows it can forge a session. Generate one with:
# >>>   openssl rand -hex 32
JWT_SECRET=__replace_with_a_long_random_string__

# Demo controls. Leave FALSE for a normal self-host instance: this hides the
# floating "Demo controls" panel (Viewing as / AI hardware tier / Reset) and the
# demo badge. Set to true ONLY if you want the sales-style demo affordances.
DEMO_MODE=false

# Host port to reach Wren on. Open http://localhost:<PORT> after `up`.
# (The app always listens on 3000 inside the container; this is the host side.)
PORT=8080

# --- Seeded login (documented default) ----------------------------------------
# The database seed creates a working manager account you log in with:
#
#     PIN:   1234
#     email: olivia@demo.wren   (role: manager)
#
# All seeded demo staff use PIN 1234. This is a KNOWN, PUBLIC default.
# >>> CHANGE THE PIN from inside the app (Staff -> edit -> set PIN), or via SQL,
# >>> before putting this on any network you don't fully trust. See README.md.

# --- Optional: AI assistant ---------------------------------------------------
# The in-app AI assistant needs an LLM provider. The easiest is a free Groq API
# key from https://console.groq.com — uncomment both lines and paste your key.
# AI_PROVIDER=groq
# GROQ_API_KEY=
